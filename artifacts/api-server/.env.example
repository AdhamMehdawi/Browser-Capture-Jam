# ── API Server ──────────────────────────────────────────────
# Copy this to .env and fill in values. NEVER commit .env.
#
# Quickstart: if you have Azure CLI access, run the commands
# in LOCAL-DEV.md to auto-populate from Key Vault.

# Node environment
NODE_ENV=development

# Server
PORT=4000

# ── Database ───────────────────────────────────────────────
# Postgres connection string (dev instance on Azure)
DATABASE_URL=postgresql://velocapadmin:<password>@velocap-pg-dev.postgres.database.azure.com:5432/velocap?sslmode=require

# ── Clerk Authentication ───────────────────────────────────
# Get from https://dashboard.clerk.com → firm-tapir-95 instance
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx

# Set to true to bypass Clerk auth entirely (local dev without Clerk)
# MOCK_AUTH=true

# ── Azure Blob Storage ─────────────────────────────────────
# Connection string for video/screenshot uploads
# Pull from Key Vault: az keyvault secret show --vault-name velocap-kv-dev --name storage-connection-string --query value -o tsv
STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=velocapstdevaue01;...

# ── Events Encryption (GDPR) ──────────────────────────────
# AES-256-GCM encryption for the events column at rest.
# Generate key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Omit to store events unencrypted (local dev).
# EVENTS_ENCRYPTION_KEY_V1=<64-char-hex-string>
# EVENTS_ENCRYPTION_KEY_CURRENT=v1

# ── Application Insights (optional) ───────────────────────
# Enables telemetry. Omit to disable.
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...

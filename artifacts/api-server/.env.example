# Database connection string
# Local: postgresql://username@localhost:5432/velorec
# Production: postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://username@localhost:5432/velorec

# Clerk Authentication - Required for production
# Get these from https://dashboard.clerk.com
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx

# Set to true to bypass Clerk auth (local development only)
# MOCK_AUTH=true

# Server port
PORT=4000

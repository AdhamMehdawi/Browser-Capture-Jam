# ---- shared ----
NODE_ENV=development

# ---- server ----
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info
COOKIE_DOMAIN=localhost
WEB_ORIGIN=http://localhost:3000
PUBLIC_API_URL=http://localhost:4000

# Postgres (docker compose)
DATABASE_URL=postgresql://veloqa:veloqa@localhost:5433/veloqa?schema=public

# JWT + cookies
JWT_SECRET=change-me-to-a-64-char-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# Object storage (MinIO defaults)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=veloqa
S3_SECRET_KEY=veloqa-secret
S3_BUCKET=veloqa-dev
S3_FORCE_PATH_STYLE=true

# Email (dev: logs to stdout; prod: set these)
MAILER_FROM="Velo QA <noreply@veloqa.local>"
# SMTP_URL=smtps://user:pass@smtp.example.com:465

# OAuth (Phase 1.5+)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ---- web ----
NEXT_PUBLIC_API_URL=http://localhost:4000
